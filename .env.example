# OpenSubtitles REST API (https://www.opensubtitles.com/en/consumers)
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# Feedback log → Dropbox (Railway: set in Variables)
# Create app: https://www.dropbox.com/developers/apps
# Scope: files.content.write
DROPBOX_ACCESS_TOKEN=
DROPBOX_FEEDBACK_PATH=/quote_memory/feedback.jsonl
# Optional: also log search queries to the same file
# DROPBOX_LOG_QUERIES=1
