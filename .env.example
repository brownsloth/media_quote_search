# Quote Memory — copy to .env for local use (optional; export vars works too)

# --- API (serving/run_api.sh, Railway) ---
PORT=8001
SERVE_INDEX_DIR=data/index/archer_full
NETFLIX_MAPPING_PATH=data/netflix/archer_episodes.json
CORS_ORIGINS=http://localhost:8888,http://127.0.0.1:8888,http://localhost:8000,http://localhost:8001

# --- Hugging Face artifacts (Railway Docker build) ---
HF_ARTIFACTS_REPO=1starun8-research/archer-quote-index
# HF_TOKEN=   # only if repo is private

# --- Netflix Shakti fetch (optional — episode /watch/ links) ---
# Paste cookie *values* only (not the "NetflixId=" prefix required but script accepts either)
NETFLIX_ID=
SECURE_NETFLIX_ID=
# Or combined:
# NETFLIX_COOKIE=NetflixId=...; SecureNetflixId=...
NETFLIX_SHOW_ID=70171942
